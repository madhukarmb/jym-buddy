rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isTrainer() {
      return signedIn()
        && exists(/databases/$(database)/documents/trainers/$(request.auth.uid));
    }

    function ownsTrainerScope(data) {
      return isTrainer() && data.trainerId == request.auth.uid;
    }

    // Trainer profile docs. Self-readable for role lookup. Writes only via
    // admin (one-off seed script with Admin SDK bypasses these rules).
    match /trainers/{uid} {
      allow read: if signedIn() && request.auth.uid == uid;
      allow write: if false;
    }

    // Clients. Trainer can read/write; client can read their own doc.
    match /clients/{uid} {
      allow read: if isTrainer() || (signedIn() && request.auth.uid == uid);
      allow create, update, delete: if isTrainer();
    }

    // Schedules: trainer scoped.
    match /schedules/{scheduleId} {
      allow read, update, delete: if ownsTrainerScope(resource.data);
      allow create: if isTrainer()
        && request.resource.data.trainerId == request.auth.uid;
    }

    // Appointments: trainer scoped; clients may read their own and update for
    // attendance validation (transition scheduled -> checked_in only).
    match /appointments/{appointmentId} {
      allow read: if ownsTrainerScope(resource.data)
        || (signedIn() && resource.data.clientId == request.auth.uid);
      allow create: if isTrainer()
        && request.resource.data.trainerId == request.auth.uid;
      allow update: if ownsTrainerScope(resource.data)
        || (signedIn()
            && resource.data.clientId == request.auth.uid
            && resource.data.status == 'scheduled'
            && request.resource.data.status == 'checked_in'
            && request.resource.data.clientId == resource.data.clientId
            && request.resource.data.trainerId == resource.data.trainerId);
      allow delete: if ownsTrainerScope(resource.data);
    }

    // Billing closures: trainer scoped.
    match /billingClosures/{closureId} {
      allow read, update, delete: if ownsTrainerScope(resource.data);
      allow create: if isTrainer()
        && request.resource.data.trainerId == request.auth.uid;
    }
  }
}
