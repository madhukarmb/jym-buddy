# Firebase Web SDK config — paste the values from the Firebase Console.
#
# Setup:
#   1. https://console.firebase.google.com → Add project → name it "simple-gym-buddy-dev".
#   2. Authentication → Sign-in method → enable Email/Password.
#   3. Firestore Database → Create database → start in production mode.
#   4. Project settings → General → Your apps → add a Web app.
#   5. Copy the firebaseConfig values below.
#   6. Save this file as `.env` (no `.example`). Expo loads `EXPO_PUBLIC_*` vars
#      automatically at build time.

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
